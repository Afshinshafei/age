---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/life/HeroSection";
import LifeCalculator from "../components/life/LifeCalculator";
---

<Layout
  title="Life in weeks, days, and heartbeats of averages"
  description="Playful calculator: translate your age and habits into rough years and smaller units using public life-table style data."
>
  <HeroSection client:load />

  <main>
    <LifeCalculator client:load />
  </main>

  <footer
    class="border-t border-border/80 bg-gradient-to-b from-muted/25 to-muted/40 py-12 text-center text-sm text-muted-foreground"
  >
    <p class="mx-auto max-w-lg px-4 leading-relaxed">
      This site is a playground: built for learning, just for fun, and to poke
      at what population averages can look like in weeks, heartbeats, and other
      silly units. Nothing here is medical advice or a crystal ball, just math
      on public-style life tables and rough habits. Enjoy the napkin stats.
    </p>
  </footer>
</Layout>
